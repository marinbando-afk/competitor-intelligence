# Railway sets DATABASE_URL and PORT automatically — you don't fill those in.
# You only need to set the two below in Railway → your service → Variables.

# A long random string used to sign login sessions. Generate one and paste it.
# (e.g. from https://generate-secret.vercel.app/32 — any 32+ random chars)
JWT_SECRET=

# Your site's public origin (where the app is served from). Comma-separate if more than one.
# Example:
#   ALLOWED_ORIGIN=https://marinbando-afk.github.io
ALLOWED_ORIGIN=*
